<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Mobile Web Minecraft</title>
    <style>
        body {
            margin: 0;
            overflow: hidden;
            background-color: #87CEEB;
            touch-action: none; /* スマホのデフォルトのスクロール等を無効化 */
            font-family: sans-serif;
            user-select: none;
        }
        canvas {
            display: block;
            width: 100vw;
            height: 100vh;
        }
        /* 画面中央の照準 */
        #crosshair {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 12px;
            height: 12px;
            border: 2px solid rgba(255, 255, 255, 0.8);
            transform: translate(-50%, -50%);
            pointer-events: none;
            border-radius: 50%;
            z-index: 10;
        }
        /* 操作用UIのコンテナ */
        #ui-container {
            position: absolute;
            bottom: 20px;
            left: 0;
            width: 100%;
            display: flex;
            justify-content: space-between;
            padding: 0 20px;
            box-sizing: border-box;
            pointer-events: none;
            z-index: 20;
        }
        .control-group {
            display: grid;
            grid-template-columns: 60px 60px 60px;
            grid-template-rows: 60px 60px;
            gap: 10px;
            pointer-events: auto;
        }
        .action-group {
            display: flex;
            flex-direction: column;
            gap: 10px;
            pointer-events: auto;
        }
        .btn {
            background: rgba(255, 255, 255, 0.4);
            border: 2px solid rgba(255, 255, 255, 0.8);
            border-radius: 12px;
            font-size: 18px;
            font-weight: bold;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            text-shadow: 1px 1px 2px black;
            touch-action: manipulation;
        }
        .btn:active {
            background: rgba(255, 255, 255, 0.7);
        }
        /* 十字キーのレイアウト調整 */
        .btn-up { grid-column: 2; grid-row: 1; }
        .btn-left { grid-column: 1; grid-row: 2; }
        .btn-down { grid-column: 2; grid-row: 2; }
        .btn-right { grid-column: 3; grid-row: 2; }

        .btn-action {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            font-size: 14px;
        }
        .btn-break { background: rgba(255, 100, 100, 0.5); }
        .btn-place { background: rgba(100, 255, 100, 0.5); }

        #title {
            position: absolute;
            top: 10px;
            width: 100%;
            text-align: center;
            color: white;
            text-shadow: 1px 1px 2px black;
            font-size: 14px;
            pointer-events: none;
        }
    </style>
</head>
<body>
    <div id="title">画面スワイプで視点変更 / ボタンで移動・ブロック操作</div>
    <div id="crosshair"></div>

    <div id="ui-container">
        <!-- 移動用パッド -->
        <div class="control-group">
            <div class="btn btn-up" id="btnW">前</div>
            <div class="btn btn-left" id="btnA">左</div>
            <div class="btn btn-down" id="btnS">後</div>
            <div class="btn btn-right" id="btnD">右</div>
        </div>
        <!-- アクション用パッド（ジャンプ・壊す・置く） -->
        <div class="action-group" style="flex-direction: row; align-items: flex-end;">
            <div class="btn btn-action" id="btnJump" style="background: rgba(100, 150, 255, 0.5);">ジャンプ</div>
            <div class="btn btn-action btn-break" id="btnBreak">壊す</div>
            <div class="btn btn-action btn-place" id="btnPlace">置く</div>
        </div>
    </div>

    <!-- Three.js CDN -->
    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
                "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
            }
        }
    </script>
    <script type="module">
        import * as THREE from 'three';

        // 1. シーン・カメラ・レンダラー
        const scene = new THREE.Scene();
        scene.fog = new THREE.Fog(0x87CEEB, 0, 40);
        const camera = new THREE.PerspectiveCamera(70, window.innerWidth / window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ antialias: false });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        document.body.appendChild(renderer.domElement);

        // 光源
        scene.add(new THREE.AmbientLight(0xffffff, 0.7));
        const dirLight = new THREE.DirectionalLight(0xffffff, 0.6);
        dirLight.position.set(10, 30, 10);
        scene.add(dirLight);

        // ブロックデータ
        const boxGeo = new THREE.BoxGeometry(1, 1, 1);
        const grassMat = new THREE.MeshLambertMaterial({ color: 0x55aa55 });
        const dirtMat = new THREE.MeshLambertMaterial({ color: 0x8b5a2b });
        const blocks = [];

        // 地面生成 (12x12)
        for (let x = -6; x < 6; x++) {
            for (let z = -6; z < 6; z++) {
                const mesh = new THREE.Mesh(boxGeo, grassMat);
                mesh.position.set(x, 0, z);
                scene.add(mesh);
                blocks.push(mesh);
            }
        }

        camera.position.set(0, 2, 5);

        // 2. スマホ用視点タッチ操作 (スワイプでカメラ回転)
        let isTouching = false;
        let prevTouchX = 0, prevTouchY = 0;
        let lon = 0, lat = 0;

        window.addEventListener('touchstart', (e) => {
            // UIボタン以外の場所をタッチしたときだけ視点移動の対象にする
            if (e.target.closest('#ui-container')) return;
            isTouching = true;
            prevTouchX = e.touches[0].clientX;
            prevTouchY = e.touches[0].clientY;
        });

        window.addEventListener('touchmove', (e) => {
            if (!isTouching) return;
            const touchX = e.touches[0].clientX;
            const touchY = e.touches[0].clientY;
            const deltaX = touchX - prevTouchX;
            const deltaY = touchY - prevTouchY;

            lon -= deltaX * 0.5;
            lat -= deltaY * 0.5;
            lat = Math.max(-85, Math.min(85, lat)); // 上下の制限

            prevTouchX = touchX;
            prevTouchY = touchY;
            updateCameraRotation();
        });

        window.addEventListener('touchend', () => { isTouching = false; });

        function updateCameraRotation() {
            const phi = THREE.MathUtils.degToRad(90 - lat);
            const theta = THREE.MathUtils.degToRad(lon);
            const target = new THREE.Vector3();
            target.x = camera.position.x + Math.sin(phi) * Math.sin(theta);
            target.y = camera.position.y + Math.cos(phi);
            target.z = camera.position.z + Math.sin(phi) * Math.cos(theta);
            camera.lookAt(target);
        }
        updateCameraRotation();

        // 3. 移動・アクションの状態管理
        const moveState = { forward: false, backward: false, left: false, right: false };
        let velocityY = 0;
        let canJump = false;

        function bindButton(id, stateKey) {
            const el = document.getElementById(id);
            el.addEventListener('touchstart', (e) => { e.preventDefault(); moveState[stateKey] = true; });
            el.addEventListener('touchend', (e) => { e.preventDefault(); moveState[stateKey] = false; });
            // PCでのデバッグ用クリック対応
            el.addEventListener('mousedown', () => { moveState[stateKey] = true; });
            el.addEventListener('mouseup', () => { moveState[stateKey] = false; });
        }
        bindButton('btnW', 'forward');
        bindButton('btnS', 'backward');
        bindButton('btnA', 'left');
        bindButton('btnD', 'right');

        document.getElementById('btnJump').addEventListener('touchstart', (e) => {
            e.preventDefault();
            if (canJump) { velocityY = 6; canJump = false; }
        });

        // 4. ブロックを壊す・置く処理 (Raycaster)
        const raycaster = new THREE.Raycaster();
        const centerScreen = new THREE.Vector2(0, 0);

        document.getElementById('btnBreak').addEventListener('touchstart', (e) => {
            e.preventDefault();
            raycaster.setFromCamera(centerScreen, camera);
            const hits = raycaster.intersectObjects(blocks);
            if (hits.length > 0 && hits[0].distance < 5) {
                scene.remove(hits[0].object);
                blocks.splice(blocks.indexOf(hits[0].object), 1);
            }
        });

        document.getElementById('btnPlace').addEventListener('touchstart', (e) => {
            e.preventDefault();
            raycaster.setFromCamera(centerScreen, camera);
            const hits = raycaster.intersectObjects(blocks);
            if (hits.length > 0 && hits[0].distance < 5) {
                const hit = hits[0];
                const newBlock = new THREE.Mesh(boxGeo, dirtMat);
                newBlock.position.copy(hit.point).add(hit.face.normal.clone().multiplyScalar(0.5));
                newBlock.position.floor().addScalar(0.5);
                scene.add(newBlock);
                blocks.push(newBlock);
            }
        });

        // 画面リサイズ
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        // 5. ループ処理
        let prevTime = performance.now();
        function animate() {
            requestAnimationFrame(animate);
            const time = performance.now();
            const delta = (time - prevTime) / 1000;
            prevTime = time;

            // 移動計算
            const speed = 4.0 * delta;
            const dir = new THREE.Vector3();
            camera.getWorldDirection(dir);
            dir.y = 0;
            dir.normalize();

            const sideDir = new THREE.Vector3(-dir.z, 0, dir.x);

            if (moveState.forward) camera.position.addScaledVector(dir, speed);
            if (moveState.backward) camera.position.addScaledVector(dir, -speed);
            if (moveState.left) camera.position.addScaledVector(sideDir, speed);
            if (moveState.right) camera.position.addScaledVector(sideDir, -speed);

            // 重力とジャンプ
            velocityY -= 15.0 * delta;
            camera.position.y += velocityY * delta;

            if (camera.position.y < 2) {
                camera.position.y = 2;
                velocityY = 0;
                canJump = true;
            }

            updateCameraRotation();
            renderer.render(scene, camera);
        }
        animate();
    </script>
</body>
</html>
